# =====================================================================
# magnet2video — 部署环境变量
# =====================================================================
# 用法:
#   cp .env.example .env
#   编辑 .env，填入真实密码 / 凭据
#   docker compose up -d
#
# 这一个文件同时承担两种职责:
#   1) compose 自动读它做 ${VAR} 替换 (例: MYSQL_ROOT_PASSWORD: ${DB_PASSWORD})
#   2) 通过 env_file: .env 注入到 app 容器里，覆盖 configs/config.yml 默认值
#
# 同一份模板既适用 server 主机也适用 worker 主机；下面用注释标了
# 「[server]」「[worker]」区分。同一台机器上无关项可以留空或注释掉。
# =====================================================================


# ---------------------------------------------------------------------
# 部署模式 [server / worker / all]
# ---------------------------------------------------------------------
# 实际由 compose 里的 `command: ["./server", "-mode=server"]` 控制；
# 这里只是给容器一个对应的 WORKER_ID 标识 (worker 主机才需要填)。
# ---------------------------------------------------------------------
WORKER_ID=                                # [worker] 例如 home-worker-01


# ---------------------------------------------------------------------
# MySQL [server]
# ---------------------------------------------------------------------
# DB_PASSWORD 同时用于:
#   - MySQL 容器初始化 (MYSQL_ROOT_PASSWORD)
#   - app 容器连接数据库 (DB_PASSWORD)
# DB_HOST=mysql 是 docker-compose 服务名,容器内可解析,不要改
# ---------------------------------------------------------------------
DB_DIALECT=mysql
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change-me-strong-db-pass
DB_NAME=magnet2video


# ---------------------------------------------------------------------
# Redis [server]
# ---------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me-strong-redis-pass
REDIS_DB=0


# ---------------------------------------------------------------------
# RabbitMQ
# ---------------------------------------------------------------------
# RABBITMQ_USER / PASS / VHOST: 仅用于 server 主机上的 RabbitMQ 容器初始化
# RABBITMQ_URL: app 真正连接的 AMQP URL
#   [server] 主机:  amqp://<user>:<pass>@rabbitmq:5672/<vhost>
#   [worker] 主机:  amqp://<user>:<pass>@<SERVER_PUBLIC_IP>:5672/<vhost>
# ---------------------------------------------------------------------
RABBITMQ_USER=worker
RABBITMQ_PASS=change-me-strong-mq-pass
RABBITMQ_VHOST=magnet
RABBITMQ_URL=amqp://worker:change-me-strong-mq-pass@rabbitmq:5672/magnet
QUEUE_TYPE=rabbitmq


# ---------------------------------------------------------------------
# 应用 [server]
# ---------------------------------------------------------------------
APP_HOST=0.0.0.0
APP_PORT=8080
JWT_SECRET=change-me-long-random-jwt-secret


# ---------------------------------------------------------------------
# 超级管理员 [server, 仅首次启动有效]
# ---------------------------------------------------------------------
SUPER_ADMIN_EMAIL=you@example.com
SUPER_ADMIN_PASSWORD=change-me-strong-admin-pass


# ---------------------------------------------------------------------
# 邮件 (可选)
# ---------------------------------------------------------------------
FROM_EMAIL=
EMAIL_SMTP=


# ---------------------------------------------------------------------
# S3 / S3 兼容 云存储 [server + worker 都需要]
# ---------------------------------------------------------------------
# server 用来生成 Signed URL / 直链；worker 用来直接上传转码后的文件。
# 两边的值必须一致。
# ---------------------------------------------------------------------
CLOUD_STORAGE_ENABLED=true
CLOUD_STORAGE_PROVIDER=s3
S3_REGION=us-east-1
S3_BUCKET_NAME=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ADDRESSING_STYLE=
S3_SIGNATURE_VERSION=
CLOUD_STORAGE_PUBLIC_URL=


# =====================================================================
# 下面这些「不」放进 .env，它们必须填进 GitHub 仓库的 Secrets:
#   Settings → Secrets and variables → Actions → New repository secret
#
#   SSH_HOST          —— 服务器公网 IP / 域名
#   SSH_USER          —— SSH 登录用户 (要在 docker 组里)
#   SSH_PRIVATE_KEY   —— SSH 私钥全文 (含 BEGIN / END 行)
#   SSH_PORT          —— 可选, 默认 22
#
# CD workflow 用这些 secrets ssh 到服务器，pull 镜像并重启。
# 不需要 GHCR 的 Token —— 包公开后服务器直接 docker pull 就行。
# =====================================================================
