# ===========================================
# Docker 部署环境配置
# 复制此文件为 .docker.env 并修改配置
# ===========================================

# ===========================================
# 数据库配置
# ===========================================
DB_DIALECT=mysql
DB_HOST=mysql                      # docker-compose 服务名
DB_PORT=3306
DB_USER=root
DB_PASSWORD=rootpassword
DB_NAME=gin-scaffold_db
# MySQL root 密码 (仅用于 docker-compose 初始化数据库)
DB_ROOT_PASSWORD=rootpassword

# ===========================================
# Redis 配置
# ===========================================
REDIS_HOST=redis                   # docker-compose 服务名
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===========================================
# 应用配置
# ===========================================
APP_HOST=0.0.0.0                   # 容器内需监听所有接口
APP_PORT=8080

# ===========================================
# JWT 认证配置
# ===========================================
JWT_SECRET=your-jwt-secret-key-here

# ===========================================
# 邮箱配置
# ===========================================
FROM_EMAIL=
EMAIL_SMTP=

# ===========================================
# 管理员账户配置
# ===========================================
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=123456

# ===========================================
# AI 服务 API Keys (可选)
# ===========================================
# DASHSCOPE_API_KEY=your-dashscope-key
# SILICONFLOW_API_KEY=your-siliconflow-key
# GEMINI_API_KEY=your-gemini-key
