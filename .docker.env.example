# ===========================================
# Docker 部署环境配置 (.docker.env)
# 复制此文件为 .docker.env 并修改配置
# ===========================================

# 环境标识
ENV=prod

# ===========================================
# 数据库配置
# ===========================================
DB_DIALECT=mysql
# Docker 容器中使用服务名作为主机名
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_PASSWORD=rootpassword
DB_NAME=gin-scaffold_db
# MySQL root 密码 (仅用于 docker-compose 初始化数据库)
DB_ROOT_PASSWORD=rootpassword

# ===========================================
# Redis 配置
# ===========================================
# Docker 容器中使用服务名作为主机名
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_DB=0

# ===========================================
# 应用配置
# ===========================================
# Docker 容器中需要监听所有接口
APP_HOST=0.0.0.0
APP_PORT=8080

# ===========================================
# JWT 认证配置
# ===========================================
JWT_SECRET=your-production-jwt-secret-key

# ===========================================
# 邮箱配置
# ===========================================
FROM_EMAIL=
EMAIL_SMTP=

# ===========================================
# 管理员账户配置
# ===========================================
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=your-secure-password

# ===========================================
# AI 服务 API Keys (可选)
# ===========================================
# DASHSCOPE_API_KEY=your-dashscope-key
# SILICONFLOW_API_KEY=your-siliconflow-key
# GEMINI_API_KEY=your-gemini-key
