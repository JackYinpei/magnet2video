# ===========================================
# 本地开发环境配置 (.local.env)
# 复制此文件为 .local.env 并修改配置
# ===========================================

# 环境标识
ENV=local

# ===========================================
# 数据库配置
# ===========================================
DB_DIALECT=postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=root
DB_PASSWORD=123456
DB_NAME=gin-scaffold_db
# SQLite 数据库文件路径 (仅当 DB_DIALECT=sqlite 时需要)
DB_PATH=./database

# ===========================================
# Redis 配置
# ===========================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===========================================
# 应用配置
# ===========================================
APP_HOST=127.0.0.1
APP_PORT=8080

# ===========================================
# JWT 认证配置
# ===========================================
JWT_SECRET=your-jwt-secret-key-here

# ===========================================
# 邮箱配置
# ===========================================
FROM_EMAIL=
EMAIL_SMTP=

# ===========================================
# 管理员账户配置
# ===========================================
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=123456

# ===========================================
# AI 服务 API Keys (可选)
# ===========================================
# DASHSCOPE_API_KEY=your-dashscope-key
# SILICONFLOW_API_KEY=your-siliconflow-key
# GEMINI_API_KEY=your-gemini-key
